# Grafana 관리자 계정
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme

# PostgreSQL 모니터링 계정 (shared_postgres와 동일한 값)
GF_PG_PASSWORD=your_postgres_password

# Telegram 알림 (BotFather에서 봇 생성 후 입력)
# 1. @BotFather에게 /newbot → 토큰 받기
# 2. 봇에게 아무 메시지 보낸 뒤 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 chat_id 확인
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789
