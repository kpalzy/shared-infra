# Caddy 시크릿 템플릿
# 실제 사용 시: cp caddy.secrets.env.example caddy.secrets.env 후 값 입력
# caddy.secrets.env 는 절대 git 커밋 금지

# DNS 인증 — Let's Encrypt wildcard 인증서 발급 시 필요 (Cloudflare 예시)
# CF_API_TOKEN=your_cloudflare_api_token_here

# Basic Auth 해시 — caddy hash-password 로 생성
# 주의: bcrypt 해시의 $ 는 반드시 $$ 로 이스케이프 (예: $$2a$$12$$...)
# 생성 방법: docker run --rm caddy caddy hash-password --plaintext "비밀번호"
# BASIC_AUTH_HASH=$$2a$$12$$replacethiswithyouractualhash
